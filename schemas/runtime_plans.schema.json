{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["run_id", "plan_id", "case_id", "plan_version", "plan", "status", "created_at", "supersedes_plan_version"],
    "properties": {
      "run_id": {"type": "string", "pattern": "^RUN-VAL-[A-Z0-9]+-[0-9]+-[0-9]{4}$"},
      "plan_id": {"type": "string", "minLength": 1},
      "case_id": {"type": "string", "minLength": 1},
      "plan_version": {"type": "integer", "minimum": 1, "maximum": 2},
      "plan": {"$ref": "resolution_plan.schema.json"},
      "status": {"enum": ["proposed", "change_requested", "approved", "executing", "completed", "failed", "manual_review"]},
      "created_at": {"type": "string", "format": "date-time"},
      "updated_at": {"type": "string", "format": "date-time"},
      "supersedes_plan_version": {"type": ["integer", "null"], "minimum": 1, "maximum": 1}
    }
  }
}
