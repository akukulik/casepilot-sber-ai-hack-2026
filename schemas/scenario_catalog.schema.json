{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://casepilot.local/schemas/scenario_catalog.schema.json",
  "title": "CasePilot approved scenario catalog",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "scenario_id",
      "version",
      "status",
      "title",
      "case_topic",
      "case_subtopic",
      "description",
      "trigger_conditions",
      "required_inputs",
      "product_types",
      "strategy_steps",
      "allowed_expertises",
      "stop_conditions",
      "source_case_ids",
      "successful_cases",
      "success_rate",
      "approved_by",
      "approved_at"
    ],
    "properties": {
      "scenario_id": {"type": "string", "pattern": "^SCN-[A-Z0-9-]+$"},
      "version": {"type": "integer", "minimum": 1},
      "status": {"const": "approved"},
      "title": {"type": "string", "minLength": 1},
      "case_topic": {"type": "string", "minLength": 1},
      "case_subtopic": {"type": "string", "minLength": 1},
      "description": {"type": "string", "minLength": 40},
      "trigger_conditions": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      },
      "required_inputs": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      },
      "product_types": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      },
      "strategy_steps": {
        "type": "array",
        "minItems": 2,
        "maxItems": 20,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["order", "action", "description", "expertise_type"],
          "properties": {
            "order": {"type": "integer", "minimum": 1, "maximum": 20},
            "action": {
              "enum": [
                "check_account_state",
                "check_pending_operations",
                "request_expertise",
                "check_account_closure_eligibility"
              ]
            },
            "description": {"type": "string", "minLength": 1},
            "expertise_type": {"type": ["string", "null"]}
          }
        }
      },
      "allowed_expertises": {
        "type": "array",
        "minItems": 1,
        "maxItems": 2,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      },
      "stop_conditions": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      },
      "source_case_ids": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "pattern": "^HIST-[A-Z0-9-]+$"}
      },
      "successful_cases": {"type": "integer", "minimum": 1},
      "success_rate": {"type": "number", "minimum": 0, "maximum": 1},
      "approved_by": {"type": "string", "minLength": 1},
      "approved_at": {"type": "string", "format": "date-time"}
    }
  }
}
