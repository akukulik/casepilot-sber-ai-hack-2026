{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://casepilot.local/schemas/scenario_candidates.schema.json",
  "title": "CasePilot scenario candidates",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "candidate_id",
      "proposed_scenario_id",
      "status",
      "title",
      "case_topic",
      "case_subtopics",
      "description",
      "trigger_conditions",
      "required_inputs",
      "strategy_steps",
      "allowed_expertises",
      "stop_conditions",
      "source_case_ids",
      "evidence_count",
      "evidence_strength",
      "review_recommendation",
      "planning_supported",
      "execution_supported",
      "required_new_actions"
    ],
    "properties": {
      "candidate_id": {"type": "string", "pattern": "^SCNC-[A-Z0-9-]+$"},
      "proposed_scenario_id": {"type": "string", "pattern": "^SCN-[A-Z0-9-]+$"},
      "status": {"const": "approved_for_mvp"},
      "title": {"type": "string", "minLength": 1},
      "case_topic": {"const": "Дебетовые карты"},
      "case_subtopics": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      },
      "description": {"type": "string", "minLength": 40},
      "trigger_conditions": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      },
      "required_inputs": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      },
      "strategy_steps": {
        "type": "array",
        "minItems": 2,
        "maxItems": 20,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["order", "action", "description", "expertise_type"],
          "properties": {
            "order": {"type": "integer", "minimum": 1, "maximum": 20},
            "action": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
            "description": {"type": "string", "minLength": 1},
            "expertise_type": {"type": ["string", "null"]}
          }
        }
      },
      "allowed_expertises": {
        "type": "array",
        "minItems": 1,
        "maxItems": 4,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      },
      "stop_conditions": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      },
      "source_case_ids": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "pattern": "^HIST-[A-Z0-9-]+$"}
      },
      "evidence_count": {"type": "integer", "minimum": 1},
      "evidence_strength": {"enum": ["single_case", "moderate", "strong"]},
      "review_recommendation": {
        "enum": ["approve_for_planning", "review_branches", "needs_more_evidence"]
      },
      "planning_supported": {"const": true},
      "execution_supported": {"const": true},
      "required_new_actions": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
      }
    }
  }
}
