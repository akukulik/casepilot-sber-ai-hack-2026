{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://casepilot.local/schemas/expertise_catalog.schema.json",
  "title": "CasePilot expertise catalog",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "expertise_type",
      "title",
      "department",
      "description",
      "required_inputs",
      "possible_results"
    ],
    "properties": {
      "expertise_type": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "title": {"type": "string", "minLength": 1},
      "department": {"type": "string", "minLength": 1},
      "description": {"type": "string", "minLength": 20},
      "required_inputs": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      },
      "possible_results": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      }
    }
  }
}
