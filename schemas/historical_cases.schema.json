{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://casepilot.local/schemas/historical_cases.schema.json",
  "title": "CasePilot historical cases",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/$defs/historicalCase"
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "transcriptItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["speaker", "timestamp", "text"],
      "properties": {
        "speaker": {"enum": ["client", "employee", "system"]},
        "timestamp": {"type": "string", "format": "date-time"},
        "text": {"type": "string", "minLength": 1}
      }
    },
    "clientContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["segment", "region", "relationship_years", "communication_language", "vulnerability_flags"],
      "properties": {
        "segment": {"type": "string", "minLength": 1},
        "region": {"type": "string", "minLength": 1},
        "relationship_years": {"type": "number", "minimum": 0},
        "communication_language": {"type": "string", "minLength": 1},
        "vulnerability_flags": {"$ref": "#/$defs/stringArray"}
      }
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product_id", "product_type", "status", "currency"],
      "properties": {
        "product_id": {"type": "string", "minLength": 1},
        "product_type": {"type": "string", "minLength": 1},
        "status": {"type": "string", "minLength": 1},
        "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
        "balance": {"type": "number"},
        "available_balance": {"type": "number"},
        "linked_account_id": {"type": "string", "minLength": 1}
      }
    },
    "planStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "action", "expertise_type", "expected_output", "requires_confirmation"],
      "properties": {
        "step": {"type": "integer", "minimum": 1},
        "action": {"type": "string", "minLength": 1},
        "expertise_type": {"type": "string", "minLength": 1},
        "expected_output": {"type": "string", "minLength": 1},
        "requires_confirmation": {"type": "boolean"}
      }
    },
    "expertiseResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expertise_type", "status", "summary", "evidence"],
      "properties": {
        "expertise_type": {"type": "string", "minLength": 1},
        "status": {"enum": ["confirmed", "not_confirmed", "needs_follow_up"]},
        "summary": {"type": "string", "minLength": 1},
        "evidence": {"$ref": "#/$defs/stringArray"}
      }
    },
    "historicalCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "client_id",
        "case_topic",
        "case_subtopic",
        "created_at",
        "priority",
        "case_description",
        "conversation_transcript",
        "client_context",
        "products",
        "synthetic_system_data",
        "resolution_plan",
        "expertise_results",
        "final_result"
      ],
      "properties": {
        "case_id": {"type": "string", "pattern": "^HIST-DC-[0-9]{3}$"},
        "client_id": {"type": "string", "pattern": "^SYN-CL-[0-9]{4}$"},
        "case_topic": {"const": "Дебетовые карты"},
        "case_subtopic": {"type": "string", "minLength": 1},
        "created_at": {"type": "string", "format": "date-time"},
        "priority": {"enum": ["low", "normal", "high", "critical"]},
        "case_description": {"type": "string", "minLength": 40},
        "conversation_transcript": {
          "type": "array",
          "minItems": 2,
          "items": {"$ref": "#/$defs/transcriptItem"}
        },
        "client_context": {"$ref": "#/$defs/clientContext"},
        "products": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/product"}
        },
        "synthetic_system_data": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        },
        "resolution_plan": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/planStep"}
        },
        "expertise_results": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/expertiseResult"}
        },
        "final_result": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "summary", "resolved_at", "client_notified"],
          "properties": {
            "status": {"enum": ["resolved", "partially_resolved", "rejected"]},
            "summary": {"type": "string", "minLength": 1},
            "resolved_at": {"type": "string", "format": "date-time"},
            "client_notified": {"type": "boolean"}
          }
        }
      }
    }
  }
}
